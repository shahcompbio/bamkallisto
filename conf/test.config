/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run shahcompbio/bamkallisto -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h',
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    // TODO nf-core: Specify the paths to your test data on nf-core/test-datasets
    // TODO nf-core: Give any required params for the test so that command line flags are not needed
    input                      = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/rnasplice/samplesheet/samplesheet_bam_transcriptome.csv'
    // Genome references
    genome_fasta               = "https://github.com/nf-core/test-datasets/raw/refs/heads/rnasplice/reference/X.fa.gz"
    gtf                        = "https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/rnasplice/reference/genes_chrX.gtf"
}
